{
  "name": "aperio-agent-web-assets",
  "version": "0.1.0",
  "description": "Frontend asset dependencies for Aperio Agent Web",
  "private": true,
  "scripts": {
    "sync:lucide": "node scripts/sync-lucide.mjs",
    "dev:frontend": "vite --config aperio_agent_web/frontend/vite.config.mjs",
    "build:frontend": "vite build --config aperio_agent_web/frontend/vite.config.mjs",
    "check:frontend": "npm run build:frontend",
    "playwright:install": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "test:e2e": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "agent-browser": "node scripts/agent-browser-local.mjs",
    "agent-browser:install": "node scripts/agent-browser-local.mjs install",
    "agent-browser:doctor": "node scripts/agent-browser-local.mjs doctor --offline --quick"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sinxy-sai/aperio.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/sinxy-sai/aperio/issues"
  },
  "homepage": "https://github.com/sinxy-sai/aperio#readme",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "katex": "^0.17.0",
    "lucide": "^1.23.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "agent-browser": "^0.27.0",
    "cross-env": "^10.1.0",
    "playwright": "^1.61.1"
  }
}
